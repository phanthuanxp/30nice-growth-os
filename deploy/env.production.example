# Production .env cho 30Nice Growth OS
# Copy file này sang .env và điền giá trị thật:
#   cp deploy/env.production.example .env
#   nano .env

# === DATABASE ===
# Lấy từ output của setup.sh (postgresql://growth_os:PASS@localhost:5432/growth_os_db)
DATABASE_URL="postgresql://growth_os:CHANGE_ME@localhost:5432/growth_os_db"

# === SESSION ===
# Tạo chuỗi ngẫu nhiên dài >= 32 ký tự:
#   openssl rand -base64 32
SESSION_SECRET="CHANGE_ME_random_32_chars_min"

# === AI (Claude) ===
# Lấy tại console.anthropic.com → API Keys
ANTHROPIC_API_KEY="sk-ant-api03-..."

# === CRON ===
# Tạo chuỗi ngẫu nhiên bất kỳ, dùng trong header x-cron-secret khi gọi cron endpoints
#   openssl rand -hex 20
CRON_SECRET="CHANGE_ME_cron_secret"

# === NEXT.JS ===
NEXTAUTH_URL="https://admin.30nice.vn"
NODE_ENV="production"
PORT=3001
